    "Container image used as the host for inspector-mode probing. Must be headless-launchable and ship bash + python3 + curl. See docs/inspector-image.md for build requirements. Empty field reverts to the built-in default." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Image conteneur utilisée comme hôte pour les sondages en mode inspecteur. Doit être lançable en mode sans interface et inclure bash + python3 + curl. Voir docs/inspector-image.md pour les exigences. Un champ vide rétablit l'image par défaut."
          }
        }
      }
    },
    "Container registry the credentials below authenticate against, for pulling the AI compute image. Default is the CANFAR Harbor host; other registries (Docker Hub, Quay, GHCR) work too." : {
      "extractionState" : "stale",
